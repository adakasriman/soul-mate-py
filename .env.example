# =============================================================================
# ENVIRONMENT CONFIGURATION — copy to .env and fill in values
# =============================================================================

# App
DJANGO_ENV=development          # development | staging | production
SECRET_KEY=your-super-secret-key-change-in-production-min-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
SITE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# =============================================================================
# DATABASE — Neon PostgreSQL
# =============================================================================
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DB_NAME=ecommerce_db
DB_USER=neon_user
DB_PASSWORD=your_neon_password
DB_HOST=ep-xxx.us-east-2.aws.neon.tech
DB_PORT=5432
DB_SSLMODE=require
DB_CONN_MAX_AGE=60              # seconds — connection pooling

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3

# =============================================================================
# JWT
# =============================================================================
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=True
JWT_BLACKLIST_AFTER_ROTATION=True
JWT_ALGORITHM=HS256

# =============================================================================
# EMAIL
# =============================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=E-Commerce Platform <noreply@yourplatform.com>

# =============================================================================
# AWS S3 (File Storage)
# =============================================================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=your-cloudfront-domain.cloudfront.net
USE_S3=False                    # Set True in production

# =============================================================================
# OAUTH (Future — Google)
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback/

# =============================================================================
# SECURITY
# =============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000
RATE_LIMIT_ANON=100/hour
RATE_LIMIT_USER=1000/hour

# =============================================================================
# SENTRY (Production Monitoring)
# =============================================================================
SENTRY_DSN=

# =============================================================================
# MISC
# =============================================================================
PAGINATION_PAGE_SIZE=20
MAX_FILE_UPLOAD_SIZE_MB=10
